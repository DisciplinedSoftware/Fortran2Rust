# LLM Configuration
LLM_PROVIDER=openai           # openai | anthropic | google | openrouter | github | ollama
LLM_MODEL=gpt-4o              # model name for the chosen provider
LLM_MAX_TOKENS=16384          # max output tokens per request (important for large generated files)
LLM_API_KEY=                  # optional generic key fallback used by openai/anthropic/google/openrouter/github

# API Keys (fill in the one you need)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
OPENROUTER_API_KEY=...
GITHUB_TOKEN=ghp-...          # GitHub token (read from 'gh auth status' or set explicitly)
OLLAMA_BASE_URL=http://localhost:11434
