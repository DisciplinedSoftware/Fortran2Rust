# LLM Configuration
LLM_PROVIDER=openai           # openai | anthropic | google | openrouter | github | ollama
LLM_MODEL=gpt-4o              # model name for the chosen provider
LLM_MAX_TOKENS=16384          # max output tokens per request (important for large generated files)
LLM_MAX_PARALLEL=2            # max parallel LLM requests in stages 7/8 (set low to avoid RAM spikes)
LLM_API_KEY=                  # optional generic key fallback used by openai/anthropic/google/openrouter/github

# API Keys (fill in the one you need)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
OPENROUTER_API_KEY=...
GITHUB_TOKEN=ghp-...          # GitHub token (read from 'gh auth status' or set explicitly)
OLLAMA_BASE_URL=http://localhost:11434

# Stage 2 (benchmark generation) memory/timing controls
S2_MAX_PARALLEL=2             # max parallel calibrations in stage 2
S2_MATRIX_N_MAX=768           # cap calibrated matrix N to limit per-benchmark memory footprint
S2_TIMING_MAX_RUNS=12         # max repeated runs used when a single call is too fast (<1ms); set 0 for unlimited
S2_DATASET_REUSE_EVERY=3      # reuse each dataset for this many runs before regenerating
